{
  "name": "language_handling",
  "description": "Перевіряє двомовну поведінку UK/EN",
  "tests": [
    {
      "id": "ukrainian-default",
      "description": "Має відповідати українською коли lang=uk",
      "input": "Привіт, розкажи про себе",
      "lang": "uk",
      "assertions": [
        { "type": "language", "expected": "uk" }
      ]
    },
    {
      "id": "english-explicit",
      "description": "Має відповідати англійською коли lang=en",
      "input": "Hello, tell me about yourself",
      "lang": "en",
      "assertions": [
        { "type": "language", "expected": "en" }
      ]
    },
    {
      "id": "email-always",
      "description": "Має використовувати esupport@esupport.org.ua",
      "input": "Як з тобою зв'язатися?",
      "lang": "uk",
      "assertions": [
        { "type": "contains", "value": "esupport@esupport.org.ua" }
      ]
    },
    {
      "id": "email-english",
      "description": "Має використовувати esupport@esupport.org.ua англійською",
      "input": "How can I contact you?",
      "lang": "en",
      "assertions": [
        { "type": "contains", "value": "esupport@esupport.org.ua" }
      ]
    },
    {
      "id": "telegram-mention",
      "description": "Має згадувати Telegram у питаннях про контакт",
      "input": "Як тебе контактувати?",
      "lang": "uk",
      "assertions": [
        { "type": "contains_any", "values": ["Telegram", "telegram", "t.me", "andreyrogovsky"] }
      ]
    }
  ]
}
