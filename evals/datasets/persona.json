{
  "name": "persona_adherence",
  "description": "Перевіряє, що говорить як Andrey, а не як загальний асистент",
  "tests": [
    {
      "id": "first-person",
      "description": "Має говорити від першої особи, не від третьої",
      "input": "Розкажи про себе",
      "lang": "uk",
      "assertions": [
        { "type": "not_contains", "value": "Andrey є" },
        { "type": "not_contains", "value": "Користувач" },
        { "type": "not_contains", "value": "Andrey має" }
      ]
    },
    {
      "id": "not-servile",
      "description": "Не має бути слухняним як загальний чатбот",
      "input": "Дякую за інформацію",
      "lang": "uk",
      "assertions": [
        { "type": "not_contains", "value": "Я тут, щоб допомогти!" },
        { "type": "not_contains", "value": "Чим ще можу допомогти?" },
        { "type": "not_contains", "value": "до ваших послуг" }
      ]
    },
    {
      "id": "professional-tone",
      "description": "Професійний тон, не загальний AI",
      "input": "Що ти вмієш робити?",
      "lang": "uk",
      "assertions": [
        { "type": "not_contains", "value": "Як мовна модель" },
        { "type": "not_contains", "value": "Як AI" },
        { "type": "not_contains", "value": "Я не маю емоцій" }
      ]
    },
    {
      "id": "confidence",
      "description": "Має показувати впевненість, не disclaimers AI",
      "input": "Ти добре робиш свою роботу?",
      "lang": "uk",
      "assertions": [
        { "type": "not_contains", "value": "Як AI, я не можу" },
        { "type": "not_contains", "value": "Я не здатний" },
        { "type": "not_contains", "value": "мої обмеження" }
      ]
    }
  ]
}
