{
  "name": "factual_accuracy",
  "description": "Перевіряє, що Andrey відповідає з правильними даними з CV",
  "tests": [
    {
      "id": "exp-years",
      "description": "Має згадати значні роки досвіду або дату початку",
      "input": "Скільки років досвіду у тебе?",
      "lang": "uk",
      "assertions": [
        { "type": "contains_any", "values": ["25", "двадцять", "1999", "2000"] },
        { "type": "not_contains", "value": "не знаю" }
      ]
    },
    {
      "id": "ai-project-name",
      "description": "Має згадати назву AI проєкту: GALA",
      "input": "Як називається твій B2B lead generation агент?",
      "lang": "uk",
      "assertions": [
        { "type": "contains", "value": "GALA" }
      ]
    },
    {
      "id": "location",
      "description": "Має згадати Україну",
      "input": "Де ти знаходишся?",
      "lang": "uk",
      "assertions": [
        { "type": "contains_any", "values": ["Україн", "Ukraine"] }
      ]
    },
    {
      "id": "ai-tools-catalog",
      "description": "Має згадати каталог 16K+ AI інструментів",
      "input": "Розкажи про AI Tool Insights",
      "lang": "uk",
      "assertions": [
        { "type": "contains_any", "values": ["16", "16000", "шістнадцять тисяч", "каталог"] }
      ]
    },
    {
      "id": "retention-rate",
      "description": "Має згадати 100% retention для AI Tool Insights",
      "input": "Який retention rate у AI Tool Insights?",
      "lang": "uk",
      "assertions": [
        { "type": "contains_any", "values": ["100%", "100", "сто відсотків"] }
      ]
    },
    {
      "id": "gala-calls",
      "description": "Має згадати 85 дзвінків/день для GALA",
      "input": "Скільки дзвінків на день робить GALA?",
      "lang": "uk",
      "assertions": [
        { "type": "contains_any", "values": ["85", "вісімдесят"] }
      ]
    },
    {
      "id": "target-roles",
      "description": "Має згадати ролі, що цікавлять",
      "input": "Які ролі тебе цікавлять?",
      "lang": "uk",
      "assertions": [
        { "type": "contains_any", "values": ["AI Engineer", "Senior AI", "MLOps", "AI Product"] }
      ]
    },
    {
      "id": "repo-public",
      "description": "Має підтвердити, що код esupport.org.ua публічний на GitHub",
      "input": "Чи є код esupport.org.ua на GitHub?",
      "lang": "uk",
      "assertions": [
        { "type": "contains_any", "values": ["публічн", "відкрит", "GitHub"] },
        { "type": "not_contains", "value": "приватн" }
      ]
    },
    {
      "id": "model-version",
      "description": "Має сказати Claude Sonnet 4 через AWS Bedrock",
      "input": "Яку модель AI ти використовуєш?",
      "lang": "uk",
      "assertions": [
        { "type": "contains_any", "values": ["Sonnet 4", "Claude Sonnet", "Bedrock"] },
        { "type": "not_contains", "value": "3.5" }
      ]
    }
  ]
}
