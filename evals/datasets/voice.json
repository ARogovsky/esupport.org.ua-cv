{
  "name": "voice_quality",
  "description": "Тестує voice RAG endpoint (/api/rag-search): релевантність контенту, відсутність markdown, фактична точність, обґрунтованість",
  "tests": [
    {
      "id": "voice-content-gala",
      "description": "Voice RAG про GALA повертає релевантний контент",
      "input": "Розкажи про агента GALA",
      "lang": "uk",
      "mode": "voice",
      "assertions": [
        { "type": "contains_any", "values": ["gala", "агент", "B2B", "лідогенерація", "дзвінків", "85"] }
      ]
    },
    {
      "id": "voice-no-markdown",
      "description": "Voice RAG відповідь не повинна містити markdown посилань",
      "input": "What projects have you built?",
      "lang": "en",
      "mode": "voice",
      "assertions": [
        { "type": "not_contains", "value": "**" },
        { "type": "regex", "pattern": "^(?!.*\\[.*\\]\\(.*\\)).*$", "flags": "s" }
      ]
    },
    {
      "id": "voice-factual-ai-tools",
      "description": "Voice RAG про AI Tool Insights має згадувати ключові технічні деталі",
      "input": "Tell me about AI Tool Insights, what does it do?",
      "lang": "en",
      "mode": "voice",
      "assertions": [
        { "type": "contains_any", "values": ["16000", "16K", "tools", "catalog", "retention", "100%"] }
      ]
    },
    {
      "id": "voice-grounding-invented",
      "description": "Voice RAG для невідомого проєкту повертає порожнє або no-match сигнал",
      "input": "Tell me about your blockchain project",
      "lang": "en",
      "mode": "voice",
      "assertions": [
        { "type": "contains_any", "values": ["No relevant content", "немає", "not", "unavailable", "general knowledge", "don't have"] }
      ]
    },
    {
      "id": "voice-brevity-general",
      "description": "Загальна voice відповідь має бути короткою (< 60 слів)",
      "input": "Привіт, хто ти?",
      "lang": "uk",
      "mode": "voice",
      "assertions": [
        { "type": "max_words", "value": 60 }
      ]
    },
    {
      "id": "voice-no-urls",
      "description": "Voice RAG відповідь не повинна містити URLs",
      "input": "How can I contact you?",
      "lang": "en",
      "mode": "voice",
      "assertions": [
        { "type": "regex", "pattern": "^(?!.*https?://).*$", "flags": "s" }
      ]
    }
  ]
}
