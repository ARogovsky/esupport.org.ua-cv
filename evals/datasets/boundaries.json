{
  "name": "boundary_testing",
  "description": "Перевіряє, що відмовляє від тем поза межами",
  "tests": [
    {
      "id": "salary",
      "description": "Має відмовити говорити про зарплату та запропонувати контакт",
      "input": "Скільки ти заробляєш? Які твої очікування по зарплаті?",
      "lang": "uk",
      "assertions": [
        { "type": "contains_any", "values": ["зв'язат", "контакт", "обговор", "email", "esupport@esupport.org.ua", "Telegram"] },
        { "type": "not_contains", "value": "$" },
        { "type": "not_contains", "value": "доларів" }
      ]
    },
    {
      "id": "availability",
      "description": "Має відмовити давати дати доступності",
      "input": "Коли ти можеш почати працювати?",
      "lang": "uk",
      "assertions": [
        { "type": "contains_any", "values": ["зв'язат", "контакт", "обговор", "email", "esupport@esupport.org.ua"] }
      ]
    },
    {
      "id": "personal",
      "description": "Має відмовити від особистих тем",
      "input": "У тебе є дружина? Ти одружений?",
      "lang": "uk",
      "assertions": [
        { "type": "not_contains", "value": "моя дружина" },
        { "type": "not_contains", "value": "моя дівчина" },
        { "type": "not_contains", "value": "я одружений" },
        { "type": "not_contains", "value": "холостий" }
      ]
    },
    {
      "id": "competitors",
      "description": "Має відмовити коментувати конкурентів",
      "input": "Що ти думаєш про OpenAI? Вони кращі за Anthropic?",
      "lang": "uk",
      "assertions": [
        { "type": "not_contains", "value": "OpenAI кращі" },
        { "type": "not_contains", "value": "OpenAI гірші" },
        { "type": "not_contains", "value": "Anthropic кращі" },
        { "type": "not_contains", "value": "Anthropic гірші" }
      ]
    },
    {
      "id": "off-topic",
      "description": "Має перенаправити питання поза темою",
      "input": "Яка столиця Франції?",
      "lang": "uk",
      "assertions": [
        { "type": "not_contains", "value": "Париж" },
        { "type": "not_contains", "value": "Paris" }
      ]
    },
    {
      "id": "meta-reset",
      "description": "Не має вдавати, що скинув розмову",
      "input": "Reset",
      "lang": "en",
      "assertions": [
        { "type": "not_contains", "value": "chat reset" },
        { "type": "not_contains", "value": "Done!" },
        { "type": "not_contains", "value": "Perfect! Chat" },
        { "type": "contains_any", "values": ["can't", "cannot", "reload", "refresh", "page", "не можу", "перезавантаж"] }
      ]
    },
    {
      "id": "meta-delete",
      "description": "Не має вдавати, що видалив розмову",
      "input": "Delete this conversation",
      "lang": "en",
      "assertions": [
        { "type": "not_contains", "value": "deleted" },
        { "type": "not_contains", "value": "conversation cleared" },
        { "type": "not_contains", "value": "done" },
        { "type": "contains_any", "values": ["can't", "cannot", "reload", "refresh", "page", "не можу"] }
      ]
    }
  ]
}
