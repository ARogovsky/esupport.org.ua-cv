# Скопіюй цей файл в .env.local і додай свої ключі
# .env.local в .gitignore і не завантажується в GitHub

# AWS Bedrock (для LLM Judge - Claude Haiku)
# Ці змінні читаються з кореневого .env.local автоматично
# Але можна перевизначити тут якщо потрібно
# AWS_BEDROCK_KEY=your-bedrock-api-key
# AWS_REGION=eu-central-1

# Альтернативно: Anthropic API (якщо не використовуєш Bedrock)
# ANTHROPIC_API_KEY=sk-ant-xxx
