{
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/fonts/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; media-src 'self' data:; script-src 'self' 'unsafe-inline' https://vercel.live; style-src 'self' 'unsafe-inline' https://vercel.live; font-src 'self' https://vercel.live; img-src 'self' data: https:; connect-src 'self' https://vercel.live https://*.pusher.com wss://*.pusher.com https://va.vercel-scripts.com https://vitals.vercel-insights.com wss://api.openai.com https://api.openai.com wss://*.cognitiveservices.azure.com https://*.cognitiveservices.azure.com; frame-src 'self' https://vercel.live https://player.mux.com https://www.youtube.com; frame-ancestors 'self'; form-action 'self'; base-uri 'self'; object-src 'none'"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(self), geolocation=()"
        },
        {
          "key": "X-Open-To",
          "value": "interesting-problems"
        },
        {
          "key": "X-Built-With",
          "value": "Claude Code"
        },
        {
          "key": "X-Evals",
          "value": "71"
        },
        {
          "key": "X-Resume",
          "value": "/llms.txt"
        }
      ]
    }
  ],
  "redirects": [
    { "source": "/pro-mene", "destination": "/about", "permanent": true },
    { "source": "/sobre-mi", "destination": "/", "permanent": true },
    { "source": "/en/", "destination": "/en", "permanent": true },
    { "source": "/:path+/", "destination": "/:path+", "permanent": true }
  ],
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/en", "destination": "/en/index.html" },
    { "source": "/about", "destination": "/about/index.html" },
    { "source": "/about-en", "destination": "/about-en/index.html" },
    { "source": "/ai-tools-katalog-doslidzhennia", "destination": "/ai-tools-katalog-doslidzhennia/index.html" },
    { "source": "/ai-tools-catalog-research", "destination": "/ai-tools-catalog-research/index.html" },
    { "source": "/perfectsquad-gaming-traffic", "destination": "/perfectsquad-gaming-traffic/index.html" },
    { "source": "/perfectsquad-gaming-traffic-en", "destination": "/perfectsquad-gaming-traffic-en/index.html" },
    { "source": "/smartcourses-edtech-platforma", "destination": "/smartcourses-edtech-platforma/index.html" },
    { "source": "/smartcourses-edtech-platform", "destination": "/smartcourses-edtech-platform/index.html" },
    { "source": "/advogram-gtm-case-study", "destination": "/advogram-gtm-case-study/index.html" },
    { "source": "/advogram-gtm-case-study-en", "destination": "/advogram-gtm-case-study-en/index.html" },
    { "source": "/offzmi-gtm-doslidzhennia", "destination": "/offzmi-gtm-doslidzhennia/index.html" },
    { "source": "/offzmi-gtm-case-study", "destination": "/offzmi-gtm-case-study/index.html" },
    { "source": "/gala-b2b-lidogeneratsiya", "destination": "/gala-b2b-lidogeneratsiya/index.html" },
    { "source": "/gala-b2b-lead-generation", "destination": "/gala-b2b-lead-generation/index.html" },
    { "source": "/pii-removal-roberta-ukrainska", "destination": "/pii-removal-roberta-ukrainska/index.html" },
    { "source": "/pii-removal-roberta-ukrainian", "destination": "/pii-removal-roberta-ukrainian/index.html" },
    { "source": "/privacidad", "destination": "/privacidad/index.html" },
    { "source": "/privacy", "destination": "/privacy/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/evaluate",
      "schedule": "0 8 * * *"
    }
  ]
}
